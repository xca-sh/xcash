#!/bin/bash

set -o errexit
set -o pipefail
set -o nounset

eval "$(python /app/config/performance.py shell-env web)"

# 生产迁移、collectstatic 与默认管理员补齐由 scripts/upgrade.sh 统一执行。
# 容器启动阶段不能隐式修改数据库，避免绕过真实数据演练流程。

# 上线兜底：检测到尚未应用的迁移即立即退出，强制运维先执行 scripts/upgrade.sh，
# 避免新代码连到陈旧 schema 产生大面积运行时错误。
python manage.py migrate --check

# --max-requests + jitter：worker 处理满额请求后优雅重启，周期性回收常驻内存
# （ORM/模板/三方库缓存累积），避免 gthread worker 长期运行内存只增不减。
# jitter 打散重启时点，防止所有 worker 同时回收造成瞬时拒服。
exec gunicorn config.wsgi:application \
  --bind 0.0.0.0:8000 \
  --chdir=/app \
  --worker-class gthread \
  --workers "${GUNICORN_WORKERS}" \
  --threads "${GUNICORN_THREADS}" \
  --max-requests 1000 \
  --max-requests-jitter 200
